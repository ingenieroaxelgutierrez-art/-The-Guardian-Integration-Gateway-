# Environment variables for Guardian Integration Gateway
# Copy this file to .env and fill in real values. NEVER commit .env to version control.

# Server
PORT=3000
NODE_ENV=development

# Encryption – must be set to a strong random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUDIT_LOG_KEY=change-this-to-a-strong-random-key-32-chars-min
CRYPTO_SALT=change-this-to-a-unique-deployment-salt

# Audit database path (JSON mock database)
AUDIT_DB_PATH=./logs/audit-db.json
